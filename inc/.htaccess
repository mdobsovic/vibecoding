# Zakaz priameho pristupu cez prehliadac k suborom v tomto priecinku (Apache).
# Druha vrstva ochrany popri straznom riadku "defined('APP') || exit;".

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 (starsie)
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
